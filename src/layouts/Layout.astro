---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
}

const { title, description, image, type } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// JSON-LD structured data
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Juan Adrián García García',
  url: 'https://adriangg.dev',
  sameAs: [
    'https://github.com/Adriangar99',
    'https://linkedin.com/in/juan-adrian-garcia-garcia',
  ],
  jobTitle: 'Software Developer',
  description:
    lang === 'es'
      ? 'Desarrollador de software con experiencia en frontend, backend y desarrollo móvil.'
      : 'Software developer with experience in frontend, backend and mobile development.',
  worksFor: {
    '@type': 'Organization',
    name: 'Acid Tango S.L.',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Juan Adrián García García — adriangg.dev',
  url: 'https://adriangg.dev',
  description:
    lang === 'es'
      ? 'Portfolio personal de Juan Adrián García García: proyectos, experiencia y contacto.'
      : 'Personal portfolio of Juan Adrián García García: projects, experience and contact.',
  author: {
    '@type': 'Person',
    name: 'Juan Adrián García García',
  },
  inLanguage: lang === 'es' ? 'es-ES' : 'en-US',
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO component handles title, description, OG, Twitter, hreflang, sitemap link -->
    <SEO title={title} description={description} image={image} type={type} />

    <!-- JSON-LD Structured Data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>

  <body class="bg-neutral-950 text-neutral-100 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:bg-purple-600 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-white focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-purple-500"
    >
      {t('nav.skip')}
    </a>

    <Header />

    <main id="main-content" class="mx-auto max-w-4xl px-6 pt-24 pb-16">
      <slot />
    </main>

    <Footer />
  </body>
</html>
