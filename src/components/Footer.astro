---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentYear = new Date().getFullYear();

const links = [
  { href: 'https://github.com/Adriangar99', label: 'GitHub', external: true },
  { href: 'https://www.linkedin.com/in/juan-adrian-garcia-garcia', label: 'LinkedIn', external: true },
  { href: 'https://x.com/adriangar99_', label: 'X', external: true },
  { href: 'mailto:adriangargar99@gmail.com', label: 'Email', external: false },
];
---

<footer class="border-t border-white/10 bg-neutral-950">
  <div class="mx-auto max-w-4xl px-6 py-8">
    <div class="flex flex-col-reverse items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-neutral-400">
        &copy; {currentYear} {t('footer.rights')} {t('footer.built')} <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-neutral-400 underline decoration-neutral-600 underline-offset-2 hover:text-white hover:decoration-white transition-colors rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purple-500">Astro<span class="sr-only"> {t('a11y.newTab')}</span></a>.
      </p>

      <nav aria-label="Social links">
        <ul class="flex items-center gap-4" role="list">
          {links.map(({ href, label, external }) => (
            <li>
              <a
                href={href}
                {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
                class="text-sm text-neutral-400 transition-colors hover:text-white rounded focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purple-500"
              >
                {label}{external && <span class="sr-only"> {t('a11y.newTab')}</span>}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>
