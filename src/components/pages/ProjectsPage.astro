---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../ProjectCard.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getClientProjects, getPersonalProjects } from '../../data/projects';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const clientProjects = getClientProjects(lang);
const personalProjects = getPersonalProjects(lang);
---

<Layout
  title={t('seo.projects.title')}
  description={t('seo.projects.description')}
>
  <section aria-labelledby="projects-heading" class="py-8">
    <header class="mb-12">
      <h1 id="projects-heading" class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {t('projects.title')}
      </h1>
      <p class="mt-3 max-w-xl text-neutral-400">
        {t('projects.subtitle')}
      </p>
    </header>

    <!-- Professional projects -->
    <section aria-labelledby="professional-heading" class="mb-12">
      <h2 id="professional-heading" class="mb-6 font-mono text-xs text-purple-400 uppercase tracking-widest">
        {t('projects.professional')}
      </h2>
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {clientProjects.map((project) => (
          <li>
            <ProjectCard
              {...project}
              viewLabel={t('projects.view')}
              newTabLabel={t('a11y.newTab')}
              techLabel={t('a11y.techUsed')}
              screenshotLabel={t('a11y.screenshotOf')}
            />
          </li>
        ))}
      </ul>
    </section>

    <!-- Personal projects -->
    <section aria-labelledby="personal-heading">
      <h2 id="personal-heading" class="mb-6 font-mono text-xs text-purple-400 uppercase tracking-widest">
        {t('projects.personal')}
      </h2>
      <ul class="grid gap-6 sm:grid-cols-2" role="list">
        {personalProjects.map((project) => (
          <li>
            <ProjectCard
              {...project}
              viewLabel={t('projects.view')}
              newTabLabel={t('a11y.newTab')}
              techLabel={t('a11y.techUsed')}
              screenshotLabel={t('a11y.screenshotOf')}
            />
          </li>
        ))}
      </ul>
    </section>
  </section>
</Layout>
