---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations, localizeHref } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout
  title={t('seo.home.title')}
  description={t('seo.home.description')}
>
  <!-- Hero -->
  <section aria-labelledby="hero-heading" class="flex min-h-[calc(100vh-10rem)] flex-col justify-center py-16">
    <p class="mb-4 font-mono text-sm text-purple-400">{t('home.greeting')}</p>

    <h1 id="hero-heading" class="text-4xl font-bold tracking-tight text-white sm:text-6xl">
      {t('home.title')}
    </h1>

    <p class="mt-4 text-xl text-neutral-400 sm:text-2xl">
      {t('home.subtitle')}
    </p>

    <p class="mt-6 max-w-xl text-base leading-relaxed text-neutral-400">
      {t('home.description')}
    </p>

    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href={localizeHref(lang, '/projects')}
        class="rounded-lg bg-purple-600 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-purple-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purple-500"
      >
        {t('home.cta.projects')}
      </a>
      <a
        href={localizeHref(lang, '/contact')}
        class="rounded-lg border border-white/10 px-5 py-2.5 text-sm font-medium text-neutral-300 transition-colors hover:border-white/30 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purple-500"
      >
        {t('home.cta.contact')}
      </a>
    </div>
  </section>

  <!-- Quick highlights -->
  <section aria-labelledby="highlights-heading" class="border-t border-white/10 py-16">
    <h2 id="highlights-heading" class="sr-only">{t('home.highlights.title')}</h2>

    <dl class="grid gap-8 sm:grid-cols-3">
      <div>
        <dt class="font-mono text-xs text-purple-400 uppercase tracking-widest">{t('home.highlights.focus.label')}</dt>
        <dd class="mt-2 text-neutral-300">{t('home.highlights.focus.value')}</dd>
      </div>
      <div>
        <dt class="font-mono text-xs text-purple-400 uppercase tracking-widest">{t('home.highlights.stack.label')}</dt>
        <dd class="mt-2 text-neutral-300">{t('home.highlights.stack.value')}</dd>
      </div>
      <div>
        <dt class="font-mono text-xs text-purple-400 uppercase tracking-widest">{t('home.highlights.location.label')}</dt>
        <dd class="mt-2 text-neutral-300">{t('home.highlights.location.value')}</dd>
      </div>
    </dl>
  </section>
</Layout>
