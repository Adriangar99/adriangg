---
interface Props {
  title: string;
  description: string;
  url?: string;
  company?: string;
  tags?: string[];
  image?: string;
  viewLabel?: string;
}

const { title, description, url, company, tags = [], image, viewLabel = 'View project' } = Astro.props;
---

<article class="group flex flex-col gap-3 rounded-xl border border-white/10 bg-white/5 p-5 transition-colors hover:border-purple-500/40 hover:bg-white/8">
  {image && (
    <img
      src={image}
      alt={`Screenshot of ${title}`}
      class="w-full rounded-lg object-cover aspect-video"
      loading="lazy"
    />
  )}

  <header class="flex flex-col gap-1">
    <h3 class="font-semibold text-white group-hover:text-purple-300 transition-colors">
      {title}
    </h3>
    {company && (
      <p class="text-xs text-neutral-500">{company}</p>
    )}
  </header>

  <p class="text-sm text-neutral-400 leading-relaxed">{description}</p>

  {tags.length > 0 && (
    <ul class="flex flex-wrap gap-2" role="list" aria-label="Technologies used">
      {tags.map((tag) => (
        <li>
          <span class="rounded-full border border-white/10 px-2.5 py-0.5 text-xs text-neutral-400 font-mono">
            {tag}
          </span>
        </li>
      ))}
    </ul>
  )}

  {url && (
    <footer class="mt-auto pt-2">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm text-purple-400 hover:text-purple-300 transition-colors"
        aria-label={`${viewLabel}: ${title}`}
      >
        {viewLabel}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 7h10v10"/>
          <path d="M7 17 17 7"/>
        </svg>
      </a>
    </footer>
  )}
</article>
