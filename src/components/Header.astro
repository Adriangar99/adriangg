---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const currentPath = Astro.url.pathname;

// Strip locale prefix to get the base path
const basePath = lang === 'en'
  ? currentPath.replace(/^\/en/, '') || '/'
  : currentPath;

const navLinks = [
  { base: '/', labelKey: 'nav.home' as const },
  { base: '/projects', labelKey: 'nav.projects' as const },
  { base: '/about', labelKey: 'nav.about' as const },
  { base: '/contact', labelKey: 'nav.contact' as const },
];

// Build locale-aware hrefs
const localizedLinks = navLinks.map(({ base, labelKey }) => ({
  href: lang === 'en' ? (base === '/' ? '/en/' : `/en${base}`) : base,
  label: t(labelKey),
  base,
}));

function isActive(base: string) {
  if (base === '/') return basePath === '/';
  return basePath.startsWith(base);
}

// Alternate language switcher URL
const altLang = lang === 'es' ? 'en' : 'es';
const altHref = altLang === 'en'
  ? (basePath === '/' ? '/en/' : `/en${basePath}`)
  : basePath;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-neutral-950/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4" aria-label="Main navigation">
    <a href={lang === 'en' ? '/en/' : '/'} class="font-mono text-sm font-semibold text-white transition-colors hover:text-purple-400">
      adriangg.dev
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-6 sm:flex">
      <ul class="flex items-center gap-6" role="list">
        {localizedLinks.map(({ href, label, base }) => (
          <li>
            <a
              href={href}
              aria-current={isActive(base) ? 'page' : undefined}
              class:list={[
                'text-sm transition-colors',
                isActive(base)
                  ? 'text-white font-medium'
                  : 'text-neutral-400 hover:text-white',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Language switcher -->
      <a
        href={altHref}
        aria-label={`Switch to ${altLang === 'en' ? 'English' : 'Español'}`}
        class="font-mono text-xs text-neutral-500 transition-colors hover:text-white border border-white/10 rounded px-2 py-1 hover:border-white/30"
      >
        {altLang === 'en' ? 'EN' : 'ES'}
      </a>
    </div>

    <!-- Mobile nav toggle -->
    <button
      id="mobile-menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label={t('nav.toggle')}
      class="sm:hidden text-neutral-400 hover:text-white transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-white/10 px-6 pb-4">
    <ul class="flex flex-col gap-3 pt-4" role="list">
      {localizedLinks.map(({ href, label, base }) => (
        <li>
          <a
            href={href}
            aria-current={isActive(base) ? 'page' : undefined}
            class:list={[
              'block text-sm transition-colors',
              isActive(base)
                ? 'text-white font-medium'
                : 'text-neutral-400 hover:text-white',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Language switcher mobile -->
    <div class="mt-4 pt-4 border-t border-white/10">
      <a
        href={altHref}
        class="font-mono text-xs text-neutral-500 transition-colors hover:text-white"
      >
        {altLang === 'en' ? '🌐 English' : '🌐 Español'}
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
