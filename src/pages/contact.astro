---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Get in touch with Adrian Garcia. Send a message, connect on LinkedIn, or check out my GitHub."
>
  <section aria-labelledby="contact-heading" class="py-8">
    <header class="mb-12">
      <h1 id="contact-heading" class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Contact
      </h1>
      <p class="mt-3 max-w-xl text-neutral-400">
        Have a project in mind, a question, or just want to say hello?
        Feel free to reach out via the form or any of the links below.
      </p>
    </header>

    <div class="grid gap-12 lg:grid-cols-2">
      <!-- Contact form -->
      <form
        name="contact"
        method="POST"
        action="/contact/success"
        class="space-y-5"
        novalidate
      >
        <div>
          <label for="name" class="mb-1.5 block text-sm font-medium text-neutral-300">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            placeholder="Your name"
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-white placeholder:text-neutral-600 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-colors"
          />
        </div>

        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-neutral-300">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="your@email.com"
            class="w-full rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-white placeholder:text-neutral-600 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-colors"
          />
        </div>

        <div>
          <label for="message" class="mb-1.5 block text-sm font-medium text-neutral-300">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="What's on your mind?"
            class="w-full resize-none rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-white placeholder:text-neutral-600 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-colors"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"
        >
          Send message
        </button>
      </form>

      <!-- Alternative contact options -->
      <aside aria-labelledby="links-heading" class="space-y-4">
        <h2 id="links-heading" class="font-mono text-xs text-indigo-400 uppercase tracking-widest">
          Or find me here
        </h2>

        <ul class="space-y-3" role="list">
          <li>
            <a
              href="https://github.com/adriangargar"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-neutral-300 hover:text-white transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              github.com/adriangargar
            </a>
          </li>
          <li>
            <a
              href="https://linkedin.com/in/adriangargar"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-neutral-300 hover:text-white transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              linkedin.com/in/adriangargar
            </a>
          </li>
        </ul>

        <p class="text-sm text-neutral-500 pt-4">
          I typically respond within 24–48 hours.
        </p>
      </aside>
    </div>
  </section>
</Layout>
