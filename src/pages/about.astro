---
import Layout from '../layouts/Layout.astro';

const skills = [
  { category: 'Languages', items: ['TypeScript', 'JavaScript', 'HTML', 'CSS'] },
  { category: 'Frameworks', items: ['Astro', 'React', 'Node.js'] },
  { category: 'Tools', items: ['Git', 'Docker', 'Cloudflare', 'Vite'] },
];
---

<Layout
  title="About"
  description="Learn more about Adrian Garcia — software developer based in Spain. My background, skills, and what I'm working on."
>
  <section aria-labelledby="about-heading" class="py-8">
    <header class="mb-12">
      <h1 id="about-heading" class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        About me
      </h1>
    </header>

    <div class="grid gap-12 lg:grid-cols-3">
      <!-- Bio -->
      <article class="lg:col-span-2 space-y-4 text-neutral-300 leading-relaxed">
        <p>
          Hi! I'm Adrian, a software developer based in Spain. I'm passionate about
          building modern web experiences that are fast, accessible, and maintainable.
        </p>
        <p>
          I enjoy working across the full stack, but my current focus is on the frontend
          — specifically on frameworks like Astro and React, performance optimization,
          and developer experience.
        </p>
        <p>
          When I'm not coding, I'm probably exploring new tools, reading about
          software architecture, or thinking about how to make things simpler.
        </p>

        <div class="pt-4">
          <a
            href="/cv.pdf"
            download
            class="inline-flex items-center gap-2 rounded-lg border border-white/10 px-5 py-2.5 text-sm font-medium text-neutral-300 transition-colors hover:border-white/30 hover:text-white"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="7 10 12 15 17 10"/>
              <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            Download CV
          </a>
        </div>
      </article>

      <!-- Skills -->
      <aside aria-labelledby="skills-heading">
        <h2 id="skills-heading" class="mb-6 font-mono text-xs text-indigo-400 uppercase tracking-widest">
          Skills
        </h2>
        <dl class="space-y-5">
          {skills.map(({ category, items }) => (
            <div>
              <dt class="mb-2 text-sm font-medium text-neutral-300">{category}</dt>
              <dd>
                <ul class="flex flex-wrap gap-2" role="list">
                  {items.map((item) => (
                    <li>
                      <span class="rounded-full border border-white/10 px-2.5 py-0.5 text-xs text-neutral-400 font-mono">
                        {item}
                      </span>
                    </li>
                  ))}
                </ul>
              </dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </section>
</Layout>
