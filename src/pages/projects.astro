---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Add your real projects here
const projects = [
  {
    title: 'adriangg.dev',
    description: 'My personal portfolio built with Astro, Tailwind CSS 4, and deployed on Cloudflare Workers. Optimized for performance, SEO, and AI readability.',
    url: 'https://github.com/adriangargar/adriangg.dev',
    tags: ['Astro', 'TypeScript', 'Tailwind CSS', 'Cloudflare Workers'],
  },
  // Add more projects here
];
---

<Layout
  title="Projects"
  description="A selection of personal and professional projects built by Adrian Garcia. Focused on web development, tooling, and developer experience."
>
  <section aria-labelledby="projects-heading" class="py-8">
    <header class="mb-12">
      <h1 id="projects-heading" class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Projects
      </h1>
      <p class="mt-3 max-w-xl text-neutral-400">
        A selection of things I've built. Personal projects, experiments, and work I'm proud of.
      </p>
    </header>

    {projects.length > 0 ? (
      <ul class="grid gap-6 sm:grid-cols-2" role="list">
        {projects.map((project) => (
          <li>
            <ProjectCard {...project} />
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-neutral-500">Projects coming soon.</p>
    )}
  </section>
</Layout>
